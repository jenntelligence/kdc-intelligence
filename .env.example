# Snowflake connection — RSA key-pair authentication
# (KDC environment requires RSA, not externalbrowser SSO)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=SCI
SNOWFLAKE_SCHEMA=L0
SNOWFLAKE_ROLE=

# RSA private key — absolute path to .p8 file (PKCS#8 format)
# Example: C:\Users\hypark5\Desktop\rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PATH=
# Passphrase if the key is encrypted (leave blank if not)
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# Server config
API_PORT=3001

# Frontend data source — mock | live | csv (PR2 에서 추가됨)
VITE_DATA_SOURCE=mock
